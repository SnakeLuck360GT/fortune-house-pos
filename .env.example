# Netlify site ID — find it in Netlify dashboard under Site settings > General
NETLIFY_SITE_ID=your-site-id-here

# Netlify Blobs token — auto-injected in Netlify runtime, needed only for local dev
# Generate one at: Netlify dashboard > Site settings > Build & deploy > Environment
NETLIFY_BLOBS_TOKEN=your-blobs-token-here

# Optional: shared secret between the Pi and the Netlify Functions for basic auth
# Generate a random string: openssl rand -hex 32
PRINT_SECRET=your-secret-here
